# --- General Operating System Files ---
.DS_Store          # Mac OS system files
Thumbs.db          # Windows thumbnail cache

# --- IDE/Editor Files ---
.idea/             # JetBrains IDEs (e.g., PhpStorm)
.vscode/           # Visual Studio Code workspace settings
*.sublime-workspace
*.bak

# --- Dependencies/Build Files ---
/vendor/           # PHP dependency manager (Composer)
/node_modules/     # JavaScript dependency manager (NPM/Yarn)
/public/build/     # Compiled assets (if you are using asset bundling like Webpack)
/storage/          # Standard directory for PHP frameworks (e.g., Laravel)

# --- Configuration and Environment Files (CRITICAL to ignore) ---
.env               # Environment configuration file (often contains passwords/keys)
.env.testing
config/config.local.php # Local config files that shouldn't be shared
*.log              # Log files

# --- XAMPP/Local Server Files ---
*.tmp              # Temporary files
